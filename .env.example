# Which model backend to use:
#   ollama    -> free, local, for your testing
#   anthropic -> production, when the app is live
EXTRACTOR_PROVIDER=ollama

# Local open-source (Ollama). Qwen2.5-VL handles Arabic documents well.
OLLAMA_MODEL=qwen2.5vl
OLLAMA_HOST=http://localhost:11434

# Production (Anthropic). Set these on your host, never commit real keys.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
